# Server Configuration
PORT=9999
MONGO_URI=mongodb://localhost:27017/toy_rental_db

# Security & Sessions
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
ACCESS_TOKEN_SECRET=your_jwt_access_secret_here
REFRESH_TOKEN_SECRET=your_jwt_refresh_secret_here

# AWS S3 Storage Configuration
AWS_S3_ACCESS_KEY=your_aws_access_key
AWS_S3_SECRET_KEY=your_aws_secret_key
AWS_S3_REGION=ap-southeast-2
AWS_S3_BUCKET_NAME=your_bucket_name_placeholder

# File Limits (e.g. 50MB) 
AWS_S3_MAX_FILE_SIZE=52428800

# Email SMTP Configuration (Google Type)
GOOGLE_MAIL_USER=your_operational_email@gmail.com
GOOGLE_MAIL_PASS=your_google_app_password
SENDGRID_SENDER_NAME=ToyRentSystem

# VNPay Payment Gateway Integration
VNP_TMN_CODE=your_vnp_tmn_code
VNP_HASH_SECRET=your_vnp_hash_secret
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:3000/vnpay_return
