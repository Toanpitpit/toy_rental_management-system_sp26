PORT=9999
MONGO_URI=mongodb://127.0.0.1:27017/toy_rental_db

# JWT Secrets - Use long random strings for production
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# AWS S3 Configuration (Optional for local image storage if implemented, but used for cloud)
AWS_S3_ACCESS_KEY=your_access_key
AWS_S3_SECRET_KEY=your_secret_key
AWS_S3_REGION=your_region
AWS_S3_BUCKET_NAME=your_bucket_name
AWS_S3_MAX_FILE_SIZE=52428800

# Google Mail (Nodemailer) - Use App Password from Google Account
GOOGLE_MAIL_USER=example@gmail.com
GOOGLE_MAIL_PASS=your_app_password_here
SENDGRID_SENDER_NAME=ToyRentSystem

# VNPay Configuration (Sandbox credentials)
VNP_TMN_CODE=your_tmn_code
VNP_HASH_SECRET=your_hash_secret
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:3000/payment-callback
